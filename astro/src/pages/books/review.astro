---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { bookUrl, getBooks } from "@/lib/books";

const books = getBooks();
const mediumItems = books.flatMap((book) =>
  book.quotes
    .filter((quote) => quote.confidence === "medium")
    .map((quote, index) => ({
      kind: "medium",
      bookId: book.id,
      title: book.title,
      author: book.author,
      readDate: book.readDate,
      url: bookUrl(book),
      index,
      reason: quote.reason,
      text: quote.text,
    }))
);
const droppedCount = books.reduce((total, book) => total + book.droppedPersonalNoteCount, 0);
const reviewItems = mediumItems;
const initialItems = reviewItems.slice(0, 120);
const serializedReviewItems = JSON.stringify({
  stats: {
    medium: mediumItems.length,
    dropped: droppedCount,
    total: reviewItems.length,
  },
  items: reviewItems,
}).replace(/</g, "\\u003c");

function itemLabel(item) {
  return "Medium";
}
---

<BaseLayout title="Books Review" robots="noindex, nofollow" wide={true}>
  <article class="book-review-page">
    <header class="book-review-header">
      <h1>Books Review</h1>
      <p>
        Medium {mediumItems.length} / Dropped {droppedCount}件は非公開データとして除外
      </p>
    </header>

    <form class="book-review-controls" id="book-review-controls" role="search">
      <label for="book-review-query">Filter</label>
      <div class="book-review-row">
        <input
          id="book-review-query"
          name="q"
          type="search"
          autocomplete="off"
          spellcheck="false"
          placeholder="タイトル、著者、本文で絞り込み"
        />
        <div class="book-review-kinds" role="group" aria-label="確認対象">
          <button type="button" class="book-review-kind is-active" data-kind="all" aria-pressed="true">All</button>
          <button type="button" class="book-review-kind" data-kind="medium" aria-pressed="false">Medium</button>
        </div>
      </div>
    </form>

    <p class="book-review-status" id="book-review-status" aria-live="polite">確認候補</p>

    <ol class="book-review-list" id="book-review-list">
      {initialItems.map((item) => (
        <li class:list={["book-review-item", `kind-${item.kind}`]}>
          <article>
            <header>
              <div class="book-review-meta">
                <span>{itemLabel(item)}</span>
                <span>{item.reason}</span>
                {item.readDate && <time datetime={item.readDate}>{item.readDate}</time>}
              </div>
              <h2><a href={item.url}>{item.title}</a></h2>
              <p>{item.author}</p>
            </header>
            <blockquote>{item.text}</blockquote>
          </article>
        </li>
      ))}
    </ol>
  </article>

  <script type="application/json" id="book-review-data" set:html={serializedReviewItems}></script>
  <script is:inline>
    (() => {
      const dataTag = document.getElementById("book-review-data");
      const input = document.getElementById("book-review-query");
      const list = document.getElementById("book-review-list");
      const status = document.getElementById("book-review-status");
      const kindButtons = Array.from(document.querySelectorAll("[data-kind]"));
      if (!dataTag || !input || !list || !status || kindButtons.length === 0) return;

      const { stats, items } = JSON.parse(dataTag.textContent || "{}");
      const state = {
        kind: "all",
        query: "",
      };

      function normalize(value) {
        return String(value).normalize("NFKC").toLowerCase().trim();
      }

      function escapeHtml(value) {
        return String(value)
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;");
      }

      function itemLabel() {
        return "Medium";
      }

      function setKind(kind) {
        state.kind = kind;
        for (const button of kindButtons) {
          const active = button.dataset.kind === kind;
          button.classList.toggle("is-active", active);
          button.setAttribute("aria-pressed", String(active));
        }
      }

      function matches(item, terms) {
        if (state.kind !== "all" && item.kind !== state.kind) return false;
        if (!terms.length) return true;
        const text = normalize([item.title, item.author, item.readDate, item.reason, item.text].join(" "));
        return terms.every((term) => text.includes(term));
      }

      function renderItem(item) {
        return `
          <li class="book-review-item kind-${escapeHtml(item.kind)}">
            <article>
              <header>
                <div class="book-review-meta">
                  <span>${escapeHtml(itemLabel())}</span>
                  <span>${escapeHtml(item.reason)}</span>
                  ${item.readDate ? `<time datetime="${escapeHtml(item.readDate)}">${escapeHtml(item.readDate)}</time>` : ""}
                </div>
                <h2><a href="${escapeHtml(item.url)}">${escapeHtml(item.title)}</a></h2>
                <p>${escapeHtml(item.author)}</p>
              </header>
              <blockquote>${escapeHtml(item.text)}</blockquote>
            </article>
          </li>
        `;
      }

      function render() {
        const terms = normalize(state.query).split(/\s+/).filter(Boolean);
        const filtered = items.filter((item) => matches(item, terms));
        const displayItems = filtered.slice(0, terms.length ? 240 : 120);
        status.textContent = terms.length || state.kind !== "all"
          ? `${filtered.length}件 / Medium ${stats.medium} / Dropped ${stats.dropped}`
          : `確認候補 ${stats.total}件`;
        list.innerHTML = displayItems.length
          ? displayItems.map(renderItem).join("")
          : '<li class="book-review-empty">該当する候補はありません。</li>';
      }

      input.addEventListener("input", (event) => {
        state.query = event.currentTarget.value;
        render();
      });

      for (const button of kindButtons) {
        button.addEventListener("click", () => {
          setKind(button.dataset.kind || "all");
          render();
        });
      }

      render();
    })();
  </script>

  <style>
    .book-review-page {
      padding-bottom: 2rem;
    }

    .book-review-header {
      margin-bottom: 1.25rem;
    }

    .book-review-header h1 {
      margin: 0 0 0.35rem;
      font-size: 30px;
      line-height: 1.25;
    }

    .book-review-header p,
    .book-review-status {
      margin: 0;
      color: #666;
      font-size: 15px;
    }

    .book-review-controls {
      margin-bottom: 1rem;
    }

    .book-review-controls label {
      display: inline-block;
      margin-bottom: 0.45rem;
      color: #555;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .book-review-row {
      display: grid;
      gap: 0.75rem;
      grid-template-columns: minmax(0, 1fr);
      align-items: center;
    }

    .book-review-row input {
      width: 100%;
      border: 1px solid #d6d6d6;
      border-radius: 4px;
      background: #fff;
      padding: 0.75rem 0.9rem;
      font-size: 16px;
      line-height: 1.3;
    }

    .book-review-kinds {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .book-review-kind {
      border: 1px solid #d6d6d6;
      border-radius: 4px;
      background: #fff;
      color: #333;
      padding: 0.45rem 0.75rem;
      font-size: 14px;
      line-height: 1.2;
      cursor: pointer;
    }

    .book-review-kind.is-active {
      border-color: #4183c4;
      color: #4183c4;
    }

    .book-review-status {
      margin-bottom: 0.75rem;
    }

    .book-review-list {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 12px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .book-review-item {
      min-width: 0;
      border: 1px solid #e3e3e3;
      border-radius: 6px;
      background: #fff;
    }

    .book-review-item.kind-dropped {
      background: #fffdf8;
    }

    .book-review-item article {
      padding: 13px;
    }

    .book-review-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      align-items: center;
      margin-bottom: 0.4rem;
      color: #666;
      font-size: 12px;
    }

    .book-review-meta span {
      border: 1px solid #ddd;
      border-radius: 999px;
      background: #fafafa;
      padding: 0.1rem 0.45rem;
      line-height: 1.3;
    }

    .kind-dropped .book-review-meta span:first-child {
      border-color: #d6b56d;
      color: #7a5a13;
    }

    .book-review-item h2 {
      margin: 0 0 0.25rem;
      font-size: 17px;
      line-height: 1.35;
      overflow-wrap: anywhere;
    }

    .book-review-item header p {
      margin: 0;
      color: #666;
      font-size: 13px;
      line-height: 1.45;
      overflow-wrap: anywhere;
    }

    .book-review-item blockquote {
      margin: 0.75rem 0 0;
      border-left: 2px solid #8a8a8a;
      padding-left: 0.8rem;
      color: #444;
      font-size: 14px;
      line-height: 1.65;
      white-space: pre-wrap;
      overflow-wrap: anywhere;
    }

    .book-review-empty {
      color: #666;
    }

    @media (min-width: 720px) {
      .book-review-row {
        grid-template-columns: minmax(0, 1fr) auto;
      }
    }
  </style>
</BaseLayout>
