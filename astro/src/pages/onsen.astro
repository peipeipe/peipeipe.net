---
import MapLayout from "@/layouts/MapLayout.astro";
import { getOnsenPlaces, summarizePlaces, type CheckinPlace } from "@/lib/checkins";

const places = getOnsenPlaces();
const stats = summarizePlaces(places);
const recentPlaces = places.slice(0, 60);

const googleMapsUrl = (place: CheckinPlace) => {
  const lat = Number(place.lat);
  const lng = Number(place.lng);
  const coordinates = Number.isFinite(lat) && Number.isFinite(lng) ? `${lat},${lng}` : "";
  const query = [place.name, coordinates].filter(Boolean).join(" ");
  return `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(query)}`;
};
---

<MapLayout
  title="温泉マップ"
  description="Foursquare / Swarm のチェックイン履歴から、訪れた温泉とサウナだけをまとめた地図です。"
  canonicalPath="/onsen/"
>
  <section class="map-app checkin-map-app">
    <header class="map-app-header">
      <div>
        <h1>温泉マップ</h1>
        <p>Foursquare / Swarm のチェックイン履歴から、訪れた温泉とサウナだけをまとめた地図です。</p>
      </div>
      <div class="map-app-stats" aria-label="Onsen stats">
        <div>
          <strong data-stat="total-onsen">{stats.count.toLocaleString()}</strong>
          <span>Onsen</span>
        </div>
        <div>
          <strong data-stat="total-checkins">{stats.checkins.toLocaleString()}</strong>
          <span>Check-ins</span>
        </div>
        <div>
          <strong>{stats.withPhotos.toLocaleString()}</strong>
          <span>Photos</span>
        </div>
        <div>
          <strong>{stats.latest?.date || ""}</strong>
          <span>Latest</span>
        </div>
      </div>
    </header>

    <div class="map-workspace">
      <section class="map-main-panel" aria-label="Onsen map">
        <div class="map-controlbar">
          <input class="map-search" id="onsen-search" type="search" placeholder="温泉名・住所・コメントで検索" aria-label="温泉検索" />
        </div>
        <div class="map-canvas-wrap">
          <div id="onsen-map" class="map-canvas"></div>
          <div class="map-loading" id="onsen-map-loading">読み込み中...</div>
        </div>
      </section>

      <aside class="map-side-panel" aria-label="Onsen places">
        <div class="panel-header">
          <h2>温泉一覧</h2>
          <span id="onsen-count-badge">{places.length}箇所</span>
        </div>
        <div class="checkin-list compact" id="onsen-list">
          {
            recentPlaces.map((place, index) => (
              <article class="checkin-item" id={`onsen-item-${index}`}>
                <button class="checkin-item-focus" type="button" data-place-index={index}>
                  <div class="checkin-item-photo">
                    {
                      place.photos?.[0] ? (
                        <img src={place.photos[0]} alt={`${place.name}の写真`} loading="lazy" />
                      ) : (
                        <div class="checkin-item-placeholder">♨️</div>
                      )
                    }
                  </div>
                  <div class="checkin-item-body">
                    <div class="checkin-item-heading">
                      <span class="checkin-item-category onsen-category">♨️ 温泉・サウナ</span>
                      <span>{place.date}</span>
                    </div>
                    <h3>{place.name}</h3>
                    <p class="checkin-item-address">{place.address}</p>
                    {place.user_comment && <p class="checkin-item-comment">{place.user_comment}</p>}
                    <div class="checkin-item-meta">{place.checkin_count}回チェックイン</div>
                  </div>
                </button>
                <a
                  class="checkin-item-map-link"
                  href={googleMapsUrl(place)}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${place.name}をGoogle Mapsで開く`}
                >
                  Google Mapsで開く
                </a>
              </article>
            ))
          }
        </div>
        <div class="checkin-empty" id="onsen-empty" hidden>表示できる温泉がありません。</div>
      </aside>
    </div>
  </section>

  <script is:inline>
    const DATA_URL = "/onsen-data.json";
    const LIST_LIMIT = 80;
    let placesData = [];
    let map;
    let markerLayer;
    let canvasRenderer;
    let markersByIndex = {};
    let currentSearch = "";
    let searchTimer = null;

    function searchableText(place) {
      return [place.name, place.address, place.user_comment, (place.categories || []).join(" ")]
        .join(" ")
        .toLowerCase();
    }

    function filteredPlaces() {
      return placesData.filter((place) => {
        if (!Number.isFinite(place.lat) || !Number.isFinite(place.lng)) return false;
        if (!currentSearch) return true;
        return place._searchText.includes(currentSearch);
      });
    }

    function markerRadius(place) {
      const count = Number(place.checkin_count) || 1;
      return Math.min(10, 5 + Math.log2(count + 1));
    }

    function googleMapsUrl(place) {
      const lat = Number(place.lat);
      const lng = Number(place.lng);
      const coordinates = Number.isFinite(lat) && Number.isFinite(lng) ? `${lat},${lng}` : "";
      const query = [place.name, coordinates].filter(Boolean).join(" ");
      return `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(query)}`;
    }

    function render() {
      const filtered = filteredPlaces();
      updateStats(filtered);
      renderMarkers(filtered);
      renderList(filtered);
      document.getElementById("onsen-empty").hidden = filtered.length > 0;
    }

    function updateStats(filtered) {
      document.querySelector('[data-stat="total-onsen"]').textContent = filtered.length.toLocaleString();
      document.querySelector('[data-stat="total-checkins"]').textContent = filtered
        .reduce((sum, place) => sum + (Number(place.checkin_count) || 0), 0)
        .toLocaleString();
      document.getElementById("onsen-count-badge").textContent = `${filtered.length.toLocaleString()}箇所`;
    }

    function renderMarkers(filtered) {
      markerLayer.clearLayers();
      markersByIndex = {};
      const bounds = [];

      filtered.forEach((place) => {
        const marker = L.circleMarker([place.lat, place.lng], {
          renderer: canvasRenderer,
          radius: markerRadius(place),
          fillColor: "#ff7a59",
          fillOpacity: 0.78,
          color: "#ffffff",
          weight: 1,
          opacity: 0.94,
        }).addTo(markerLayer);

        marker.bindPopup(popupHtml(place), { maxWidth: 270, className: "custom-leaflet-popup" });
        marker.on("click", () => highlightPlace(place._index));
        markersByIndex[place._index] = marker;
        bounds.push([place.lat, place.lng]);
      });

      if (bounds.length > 1) map.fitBounds(bounds, { padding: [45, 45], maxZoom: 14 });
      else if (bounds.length === 1) map.setView(bounds[0], 14);
    }

    function renderList(filtered) {
      const list = document.getElementById("onsen-list");
      const visible = filtered.slice(0, LIST_LIMIT);
      list.innerHTML = visible
        .map((place) => {
          const photo = place.photos && place.photos.length
            ? `<img src="${escapeHtml(place.photos[0])}" alt="${escapeHtml(place.name)}の写真" loading="lazy">`
            : '<div class="checkin-item-placeholder">♨️</div>';
          const comment = place.user_comment ? `<p class="checkin-item-comment">${escapeHtml(place.user_comment)}</p>` : "";
          const mapsUrl = googleMapsUrl(place);
          return `
            <article class="checkin-item" id="onsen-item-${place._index}">
              <button class="checkin-item-focus" type="button" data-place-index="${place._index}">
                <div class="checkin-item-photo">${photo}</div>
                <div class="checkin-item-body">
                  <div class="checkin-item-heading">
                    <span class="checkin-item-category onsen-category">♨️ 温泉・サウナ</span>
                    <span>${escapeHtml(place.date || "")}</span>
                  </div>
                  <h3>${escapeHtml(place.name || "")}</h3>
                  <p class="checkin-item-address">${escapeHtml(place.address || "")}</p>
                  ${comment}
                  <div class="checkin-item-meta">${Number(place.checkin_count) || 1}回チェックイン</div>
                </div>
              </button>
              <a class="checkin-item-map-link" href="${escapeHtml(mapsUrl)}" target="_blank" rel="noopener noreferrer" aria-label="${escapeHtml(place.name || "")}をGoogle Mapsで開く">Google Mapsで開く</a>
            </article>
          `;
        })
        .join("");

      list.querySelectorAll("[data-place-index]").forEach((button) => {
        button.addEventListener("click", () => focusPlace(Number(button.dataset.placeIndex)));
      });

      if (filtered.length > visible.length) {
        list.insertAdjacentHTML("beforeend", `<p class="checkin-list-note">先頭 ${visible.length} 件を表示しています。検索で絞り込めます。</p>`);
      }
    }

    function focusPlace(index) {
      const place = placesData[index];
      if (!place) return;
      map.setView([place.lat, place.lng], 15, { animate: true, duration: 0.8 });
      if (markersByIndex[index]) setTimeout(() => markersByIndex[index].openPopup(), 250);
      highlightPlace(index);
    }

    function highlightPlace(index) {
      document.querySelectorAll(".checkin-item").forEach((item) => item.classList.remove("active"));
      const target = document.getElementById(`onsen-item-${index}`);
      if (target) {
        target.classList.add("active");
      }
    }

    function popupHtml(place) {
      const photo = place.photos && place.photos.length ? place.photos[0] : "";
      const photoBlock = photo ? `<div class="popup-image"><img src="${escapeHtml(photo)}" alt="${escapeHtml(place.name || "")}"></div>` : "";
      const commentBlock = place.user_comment ? `<div class="popup-comment">"${escapeHtml(place.user_comment)}"</div>` : "";
      const dateBlock = place.date ? `<div class="popup-date">📅 ${escapeHtml(place.date)} 訪問</div>` : "";
      const mapsBlock = `<a class="popup-map-link" href="${escapeHtml(googleMapsUrl(place))}" target="_blank" rel="noopener noreferrer">Google Mapsで開く</a>`;
      return `<div class="map-popup-content">${photoBlock}<h4 class="popup-title">♨️ ${escapeHtml(place.name || "")}</h4><p class="popup-address">📍 ${escapeHtml(place.address || "")}</p>${commentBlock}${dateBlock}${mapsBlock}</div>`;
    }

    function escapeHtml(value) {
      return String(value == null ? "" : value).replace(/[&<>"']/g, (character) => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      })[character]);
    }

    async function loadData() {
      const response = await fetch(DATA_URL);
      if (!response.ok) throw new Error("onsen-data.json load failed");
      const payload = await response.json();
      placesData = Array.isArray(payload.places) ? payload.places : [];
      placesData.forEach((place, index) => {
        place._index = index;
        place._searchText = searchableText(place);
      });
      document.getElementById("onsen-map-loading").hidden = true;
      render();
    }

    document.addEventListener("DOMContentLoaded", () => {
      const search = document.getElementById("onsen-search");
      search.addEventListener("input", (event) => {
        window.clearTimeout(searchTimer);
        searchTimer = window.setTimeout(() => {
          currentSearch = event.target.value.trim().toLowerCase();
          render();
        }, 160);
      });

      canvasRenderer = L.canvas({ padding: 0.5 });
      map = L.map("onsen-map", {
        preferCanvas: true,
        scrollWheelZoom: false,
        renderer: canvasRenderer,
        zoomControl: true,
      }).setView([36.2048, 138.2529], 5);

      map.on("focus", () => map.scrollWheelZoom.enable());
      map.on("blur", () => map.scrollWheelZoom.disable());
      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        maxZoom: 19,
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      }).addTo(map);
      markerLayer = L.layerGroup().addTo(map);
      requestAnimationFrame(() => map.invalidateSize());
      loadData().catch((error) => {
        console.error(error);
        document.getElementById("onsen-map-loading").textContent = "データの読み込みに失敗しました";
      });
    });
  </script>
</MapLayout>
