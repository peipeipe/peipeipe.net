---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buildSearchIndex } from "@/lib/search";

const searchIndex = await buildSearchIndex();
const initialResults = searchIndex.items.slice(0, 12);
const serializedSearchIndex = JSON.stringify(searchIndex).replace(/</g, "\\u003c");
---

<BaseLayout title="Search" robots="noindex, nofollow" wide={true}>
  <article class="search-page">
    <header class="search-header">
      <h1>Search</h1>
      <p class="search-summary">
        Posts {searchIndex.stats.posts} / Diary {searchIndex.stats.diary}
      </p>
    </header>

    <form class="search-form" id="search-form" role="search">
      <label class="search-label" for="search-query">Query</label>
      <div class="search-input-row">
        <input
          id="search-query"
          name="q"
          type="search"
          autocomplete="off"
          spellcheck="false"
          placeholder="Search"
        />
        <div class="search-kinds" role="group" aria-label="検索対象">
          <button type="button" class="search-kind is-active" data-kind="all" aria-pressed="true">All</button>
          <button type="button" class="search-kind" data-kind="post" aria-pressed="false">Posts</button>
          <button type="button" class="search-kind" data-kind="diary" aria-pressed="false">Diary</button>
        </div>
      </div>
    </form>

    <div class="search-meta" aria-live="polite">
      <p id="search-status">最近の更新</p>
      <p class="search-counts">
        <span>Posts {searchIndex.stats.posts}</span>
        <span>Diary {searchIndex.stats.diary}</span>
      </p>
    </div>

    <ol class="search-results" id="search-results">
      {initialResults.map((item) => (
        <li class:list={["search-result", `kind-${item.kind}`]}>
          <a class="search-result-link" href={item.url}>
            <div class="search-result-body">
              <div class="search-result-meta">
                <span class="search-badge">{item.kind === "post" ? "Post" : "Diary"}</span>
                <time datetime={item.date}>{item.date}</time>
              </div>
              <h2>{item.title}</h2>
              <p>{item.excerpt}</p>
            </div>
          </a>
        </li>
      ))}
    </ol>
  </article>

  <script type="application/json" id="search-data" set:html={serializedSearchIndex}></script>
  <script is:inline>
    (() => {
      const dataTag = document.getElementById("search-data");
      const form = document.getElementById("search-form");
      const input = document.getElementById("search-query");
      const results = document.getElementById("search-results");
      const status = document.getElementById("search-status");
      const kindButtons = Array.from(document.querySelectorAll("[data-kind]"));

      if (!dataTag || !form || !input || !results || !status || kindButtons.length === 0) return;

      const { items } = JSON.parse(dataTag.textContent || "{}");
      const state = {
        query: "",
        kind: "all",
      };

      function normalize(value) {
        return value.normalize("NFKC").toLowerCase().trim();
      }

      function scoreItem(item, terms, query) {
        const haystack = normalize([item.title, item.excerpt, item.plainText, item.date, item.kind, item.url].join(" "));
        let score = 0;

        for (const term of terms) {
          if (!haystack.includes(term)) return -1;
          score += 20;

          const title = normalize(item.title);
          const excerpt = normalize(item.excerpt);
          const plainText = normalize(item.plainText);
          if (title.includes(term)) score += 20;
          if (excerpt.includes(term)) score += 6;
          if (plainText.includes(term)) score += 12;
          if (item.url.includes(term)) score += 3;
        }

        const title = normalize(item.title);
        if (title.startsWith(query)) score += 10;

        const dateScore = Date.parse(item.date);
        if (!Number.isNaN(dateScore)) score += dateScore / 1000000000;

        return score;
      }

      function makeSnippet(item, terms) {
        if (!terms.length) return item.excerpt;

        const text = item.plainText || item.excerpt;
        const normalized = normalize(text);
        let matchIndex = -1;
        let matchLength = 0;

        for (const term of terms) {
          const index = normalized.indexOf(term);
          if (index !== -1 && (matchIndex === -1 || index < matchIndex)) {
            matchIndex = index;
            matchLength = term.length;
          }
        }

        if (matchIndex === -1) return item.excerpt;

        const start = Math.max(0, matchIndex - 40);
        const end = Math.min(text.length, matchIndex + matchLength + 90);
        const prefix = start > 0 ? "…" : "";
        const suffix = end < text.length ? "…" : "";
        return `${prefix}${text.slice(start, end)}${suffix}`;
      }

      function escapeHtml(value) {
        return value
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;");
      }

      function itemMarkup(item) {
        return `
          <li class="search-result kind-${item.kind}">
            <a class="search-result-link" href="${escapeHtml(item.url)}">
              <div class="search-result-body">
                <div class="search-result-meta">
                  <span class="search-badge">${item.kind === "post" ? "Post" : "Diary"}</span>
                  <time datetime="${escapeHtml(item.date)}">${escapeHtml(item.date)}</time>
                </div>
                <h2>${escapeHtml(item.title)}</h2>
                <p>${escapeHtml(item.snippet)}</p>
              </div>
            </a>
          </li>
        `;
      }

      function setKind(kind) {
        state.kind = kind;
        for (const button of kindButtons) {
          const active = button.dataset.kind === kind;
          button.classList.toggle("is-active", active);
          button.setAttribute("aria-pressed", String(active));
        }
      }

      function applyUrlState() {
        const params = new URLSearchParams(window.location.search);
        state.query = params.get("q") || "";
        const nextKind = params.get("kind") || "all";
        state.kind = kindButtons.some((button) => button.dataset.kind === nextKind) ? nextKind : "all";
        input.value = state.query;
        setKind(state.kind);
      }

      function updateUrl() {
        const params = new URLSearchParams();
        if (state.query) params.set("q", state.query);
        if (state.kind !== "all") params.set("kind", state.kind);
        const nextUrl = `${window.location.pathname}${params.toString() ? `?${params.toString()}` : ""}`;
        window.history.replaceState({}, "", nextUrl);
      }

      function render() {
        const query = normalize(state.query);
        const terms = query ? query.split(/\s+/).filter(Boolean) : [];
        const filtered = items
          .filter((item) => state.kind === "all" || item.kind === state.kind)
          .map((item) => ({
            item,
            score: terms.length ? scoreItem(item, terms, query) : 0,
          }))
          .filter((entry) => !terms.length || entry.score >= 0)
          .sort((a, b) => (terms.length ? b.score - a.score : 0) || b.item.date.localeCompare(a.item.date))
          .map((entry) => ({
            ...entry.item,
            snippet: makeSnippet(entry.item, terms),
          }));

        const displayItems = terms.length ? filtered.slice(0, 60) : filtered.slice(0, 12);

        status.textContent = terms.length
          ? `${filtered.length}件見つかりました`
          : "最近の更新";

        results.innerHTML = displayItems.length
          ? displayItems.map(itemMarkup).join("")
          : '<li class="search-empty">該当する項目はありません。</li>';

        updateUrl();
      }

      input.addEventListener("input", (event) => {
        state.query = event.currentTarget.value;
        render();
      });

      for (const button of kindButtons) {
        button.addEventListener("click", () => {
          setKind(button.dataset.kind || "all");
          render();
        });
      }

      form.addEventListener("submit", (event) => {
        event.preventDefault();
        render();
      });

      window.addEventListener("popstate", applyUrlState);

      applyUrlState();
      render();
    })();
  </script>

  <style>
    .search-page {
      padding-bottom: 2rem;
    }

    .search-header {
      margin-bottom: 1.5rem;
    }

    .search-header h1 {
      margin: 0 0 0.5rem;
      font-size: 28px;
      line-height: 1.2;
    }

    .search-summary {
      margin: 0;
      color: var(--color-muted);
      font-size: 16px;
      line-height: 1.5;
    }

    .search-form {
      margin-bottom: 1rem;
    }

    .search-label {
      display: inline-block;
      margin-bottom: 0.5rem;
      color: var(--color-muted);
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .search-input-row {
      display: grid;
      gap: 0.75rem;
      align-items: center;
      grid-template-columns: minmax(0, 1fr);
    }

    .search-kinds {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .search-kind {
      border: 1px solid var(--color-border-strong);
      border-radius: 4px;
      background: var(--color-surface);
      color: var(--color-text);
      padding: 0.45rem 0.75rem;
      font-size: 14px;
      line-height: 1.2;
      cursor: pointer;
    }

    .search-kind.is-active {
      border-color: var(--color-link);
      color: var(--color-link);
    }

    #search-query {
      width: 100%;
      border: 1px solid var(--color-border-strong);
      border-radius: 4px;
      padding: 0.75rem 0.9rem;
      font-size: 16px;
      line-height: 1.3;
      background: var(--color-surface);
      color: var(--color-text);
    }

    #search-query:focus {
      outline: 2px solid var(--focus-ring);
      outline-offset: 1px;
    }

    .search-meta {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: 0.75rem;
      margin: 0 0 1rem;
      color: var(--color-muted);
      font-size: 14px;
    }

    .search-meta p {
      margin: 0;
    }

    .search-counts {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .search-results {
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .search-result {
      border-top: 1px solid var(--color-border-soft);
    }

    .search-result-link {
      display: grid;
      align-items: start;
      padding: 1rem 0;
      color: inherit;
      text-decoration: none;
    }

    .search-result-link:hover h2 {
      color: var(--color-link);
    }

    .search-result-body {
      min-width: 0;
    }

    .search-result-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      align-items: center;
      margin-bottom: 0.35rem;
      color: var(--color-muted);
      font-size: 13px;
    }

    .search-badge {
      display: inline-flex;
      align-items: center;
      border: 1px solid var(--color-border-strong);
      border-radius: 999px;
      padding: 0.12rem 0.5rem;
      background: var(--color-surface-soft);
      font-size: 12px;
      line-height: 1.2;
    }

    .search-result h2 {
      margin: 0 0 0.4rem;
      font-size: 20px;
      line-height: 1.35;
      overflow-wrap: anywhere;
    }

    .search-result p {
      margin: 0;
      color: var(--color-muted);
      line-height: 1.6;
      overflow-wrap: anywhere;
    }

    .search-empty {
      padding: 1rem 0;
      color: var(--color-muted);
    }

    @media (min-width: 720px) {
      .search-input-row {
        grid-template-columns: minmax(0, 1fr) auto;
      }
    }
  </style>
</BaseLayout>
