---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getDiaryEntries } from "@/lib/content";

const entries = await getDiaryEntries();
---

<BaseLayout title="日記一覧">
  <h1>日記一覧</h1>
  <p>AIに食わせるために日記を書く</p>
  <div class="posts">
    {entries.map((entry) => (
      <article class="post">
        <h1><a href={entry.url}>{entry.title}</a></h1>
        <div class="entry">
          <p>{entry.excerpt}</p>
        </div>
      </article>
    ))}
  </div>
</BaseLayout>
