---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getDiaryEntries } from "@/lib/content";

const entries = await getDiaryEntries();
const groupedEntries = groupEntriesByMonth(entries);

function groupEntriesByMonth(entries) {
  const groups = [];

  for (const entry of entries) {
    const monthKey = `${entry.date.getFullYear()}-${entry.date.getMonth()}`;
    const lastGroup = groups.at(-1);
    const imageSrcs = getImageSrcs(entry.html);
    const item = { ...entry, imageSrcs };

    if (lastGroup?.key === monthKey) {
      lastGroup.entries.push(item);
      lastGroup.photoItems.push(...getPhotoItems(item));
    } else {
      groups.push({
        key: monthKey,
        label: `${entry.date.getFullYear()}年${entry.date.getMonth() + 1}月`,
        entries: [item],
        photoItems: getPhotoItems(item),
      });
    }
  }

  return groups;
}

function getImageSrcs(html) {
  const withoutLinkCards = html.replace(/<a\b(?=[^>]*\bclass="[^"]*\blink-card\b[^"]*")[\s\S]*?<\/a>/g, "");
  return [...withoutLinkCards.matchAll(/<img\s[^>]*src="([^"]+)"/g)].map((match) => match[1]);
}

function getPhotoItems(entry) {
  return entry.imageSrcs.map((src) => ({
    src,
    title: entry.title,
    url: entry.url,
  }));
}
---

<BaseLayout title="日記一覧">
  <h1>日記一覧</h1>
  <p>AIに食わせるために日記を書く</p>
  <div class="diary-archive">
    {groupedEntries.map((group) => (
      <section class="diary-month">
        <h2>{group.label}</h2>
        {group.photoItems.length > 0 && (
          <div class="diary-month-photos" aria-label={`${group.label}の写真`}>
            {group.photoItems.map((photo) => (
              <a href={photo.url} title={photo.title}>
                <img src={photo.src} alt="" loading="lazy" />
              </a>
            ))}
          </div>
        )}
        <ol class="diary-list">
          {group.entries.map((entry) => (
            <li class="diary-list-item">
              <a href={entry.url}>
                <span>{entry.title}</span>
              </a>
            </li>
          ))}
        </ol>
      </section>
    ))}
  </div>
</BaseLayout>
