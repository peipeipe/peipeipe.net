---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getDiaryEntries } from "@/lib/content";

export async function getStaticPaths() {
  const entries = await getDiaryEntries();
  return entries.map((entry) => ({
    params: { date: entry.url.replace(/^\/diary\/|\/$/g, "") },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const diaryDate = entry.title;
const entryUrl = new URL(entry.url, "https://www.peipeipe.net").toString();
const diaryJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: entry.title,
  description: entry.excerpt,
  datePublished: entry.date.toISOString(),
  dateModified: entry.date.toISOString(),
  mainEntityOfPage: entryUrl,
  url: entryUrl,
  inLanguage: "ja",
  author: {
    "@type": "Person",
    name: "peipeipe",
    url: "https://www.peipeipe.net/about",
  },
  publisher: {
    "@type": "Person",
    name: "peipeipe",
    url: "https://www.peipeipe.net",
  },
};
---

<BaseLayout
  title={entry.title}
  description={entry.excerpt}
  canonicalPath={entry.url}
  type="article"
  publishedTime={entry.date}
  modifiedTime={entry.date}
  jsonLd={diaryJsonLd}
>
  <article class="diary-entry">
    <header class="diary-header">
      <h1 class="diary-date">{diaryDate}</h1>
    </header>

    <div class="diary-content" set:html={entry.html} />
  </article>

  <div class="diary-lightbox" id="diary-lightbox" role="dialog" aria-modal="true" aria-hidden="true">
    <button type="button" class="diary-lightbox-close" aria-label="閉じる">✕</button>
    <img src="" alt="">
  </div>

  <script is:inline>
    (function() {
      var content = document.querySelector(".diary-content");
      if (!content) return;
      document.body.classList.add("js-diary");
      Array.from(content.children).forEach(function(el) {
        if (el.tagName === "H2") {
          var currentBlock = document.createElement("div");
          currentBlock.className = "diary-block";
          content.insertBefore(currentBlock, el);
          currentBlock.appendChild(el);
          return;
        }
        var blocks = content.querySelectorAll(".diary-block");
        var latestBlock = blocks[blocks.length - 1];
        if (latestBlock) latestBlock.appendChild(el);
      });
    })();
  </script>

  <script is:inline>
    (function() {
      var content = document.querySelector(".diary-content");
      var lightbox = document.getElementById("diary-lightbox");
      if (!content || !lightbox) return;
      var lightboxImg = lightbox.querySelector("img");
      var closeBtn = lightbox.querySelector(".diary-lightbox-close");

      function openLightbox(src, alt) {
        lightboxImg.src = src;
        lightboxImg.alt = alt || "";
        lightbox.classList.add("open");
        lightbox.setAttribute("aria-hidden", "false");
        document.body.classList.add("diary-lightbox-open");
      }

      function closeLightbox() {
        lightbox.classList.remove("open");
        lightbox.setAttribute("aria-hidden", "true");
        document.body.classList.remove("diary-lightbox-open");
        lightboxImg.src = "";
      }

      Array.from(content.querySelectorAll("img")).forEach(function(img) {
        if (img.closest(".link-card-media") || img.closest(".krb-amzlt-image")) return;
        img.classList.add("diary-content-image");
        img.addEventListener("click", function() {
          openLightbox(img.currentSrc || img.src, img.alt);
        });
      });

      lightbox.addEventListener("click", function(event) {
        if (event.target === lightbox || event.target === closeBtn) closeLightbox();
      });

      document.addEventListener("keydown", function(event) {
        if (event.key === "Escape" && lightbox.classList.contains("open")) closeLightbox();
      });
    })();
  </script>
</BaseLayout>
