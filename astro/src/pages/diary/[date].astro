---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getDiaryEntries } from "@/lib/content";

export async function getStaticPaths() {
  const entries = await getDiaryEntries();
  return entries.map((entry) => ({
    params: { date: entry.url.replace(/^\/diary\/|\/$/g, "") },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const diaryDate = entry.title;
---

<BaseLayout title={entry.title}>
  <article class="diary-entry">
    <header class="diary-header">
      <h1 class="diary-date">{diaryDate}</h1>
    </header>

    <div class="diary-content" set:html={entry.html} />
  </article>

  <script is:inline>
    (function() {
      var content = document.querySelector(".diary-content");
      if (!content) return;
      document.body.classList.add("js-diary");
      Array.from(content.children).forEach(function(el) {
        if (el.tagName === "H2") {
          var currentBlock = document.createElement("div");
          currentBlock.className = "diary-block";
          content.insertBefore(currentBlock, el);
          currentBlock.appendChild(el);
          return;
        }
        var blocks = content.querySelectorAll(".diary-block");
        var latestBlock = blocks[blocks.length - 1];
        if (latestBlock) latestBlock.appendChild(el);
      });
    })();
  </script>
</BaseLayout>
