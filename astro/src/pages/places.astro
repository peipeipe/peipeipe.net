---
import MapLayout from "@/layouts/MapLayout.astro";
import { categorySummary, getPlaces, summarizePlaces } from "@/lib/checkins";

const places = getPlaces();
const stats = summarizePlaces(places);
const categories = categorySummary(places);
const recentPlaces = places.slice(0, 60);
---

<MapLayout
  title="チェックイン場所マップ"
  description="Foursquare / Swarm のチェックイン履歴をカテゴリ別に眺める地図です。"
  canonicalPath="/places/"
>
  <section class="map-app checkin-map-app">
    <header class="map-app-header">
      <div>
        <h1>チェックイン場所マップ</h1>
        <p>Foursquare / Swarm のチェックイン履歴をカテゴリ別に眺める地図です。</p>
      </div>
      <div class="map-app-stats" aria-label="Places stats">
        <div>
          <strong data-stat="total-places">{stats.count.toLocaleString()}</strong>
          <span>Places</span>
        </div>
        <div>
          <strong data-stat="total-checkins">{stats.checkins.toLocaleString()}</strong>
          <span>Check-ins</span>
        </div>
        <div>
          <strong data-stat="visible-places">{stats.count.toLocaleString()}</strong>
          <span>Visible</span>
        </div>
        <div>
          <strong>{stats.latest?.date || ""}</strong>
          <span>Latest</span>
        </div>
      </div>
    </header>

    <div class="map-workspace">
      <section class="map-main-panel" aria-label="Places map">
        <div class="map-controlbar checkin-controlbar">
          <input class="map-search" id="places-search" type="search" placeholder="場所名・住所・カテゴリで検索" aria-label="場所検索" />
          <div class="segmented-control checkin-filter" aria-label="Category filter">
            <button class="active" type="button" data-group="all">すべて</button>
            {
              categories.slice(0, 8).map((category) => (
                <button type="button" data-group={category.key}>
                  {category.emoji} {category.label}
                </button>
              ))
            }
          </div>
        </div>
        <div class="map-canvas-wrap">
          <div id="places-map" class="map-canvas"></div>
          <div class="map-loading" id="places-map-loading">読み込み中...</div>
        </div>
      </section>

      <aside class="map-side-panel" aria-label="Check-in places">
        <div class="panel-header">
          <h2>場所一覧</h2>
          <span id="places-count-badge">{places.length}箇所</span>
        </div>
        <div class="checkin-list compact" id="places-list">
          {
            recentPlaces.map((place, index) => (
              <article class="checkin-item" id={`place-item-${index}`}>
                <button class="checkin-item-focus" type="button" data-place-index={index}>
                  <div class="checkin-item-photo">
                    {
                      place.photos?.[0] ? (
                        <img src={place.photos[0]} alt={`${place.name}の写真`} loading="lazy" />
                      ) : (
                        <div class="checkin-item-placeholder">{place.category_emoji}</div>
                      )
                    }
                  </div>
                  <div class="checkin-item-body">
                    <div class="checkin-item-heading">
                      <span class="checkin-item-category" style={`background:${place.category_color}`}>
                        {place.category_emoji} {place.category_label}
                      </span>
                      <span>{place.date}</span>
                    </div>
                    <h3>{place.name}</h3>
                    <p class="checkin-item-address">{place.address}</p>
                    {place.user_comment && <p class="checkin-item-comment">{place.user_comment}</p>}
                    <div class="checkin-item-meta">{place.checkin_count}回チェックイン</div>
                  </div>
                </button>
              </article>
            ))
          }
        </div>
        <div class="checkin-empty" id="places-empty" hidden>表示できるチェックイン場所がありません。</div>
      </aside>
    </div>
  </section>

  <script is:inline>
    const DATA_URL = "/places-data.json";
    const LIST_LIMIT = 80;
    let placesData = [];
    let map;
    let markerLayer;
    let canvasRenderer;
    let markersByIndex = {};
    let currentGroup = "all";
    let currentSearch = "";
    let searchTimer = null;

    function searchableText(place) {
      return [place.name, place.address, place.user_comment, place.category_label, (place.categories || []).join(" ")]
        .join(" ")
        .toLowerCase();
    }

    function filteredPlaces() {
      return placesData.filter((place) => {
        if (!Number.isFinite(place.lat) || !Number.isFinite(place.lng)) return false;
        if (currentGroup !== "all" && place.category_group !== currentGroup) return false;
        if (!currentSearch) return true;
        return place._searchText.includes(currentSearch);
      });
    }

    function markerRadius(place) {
      const count = Number(place.checkin_count) || 1;
      return Math.min(9, 4 + Math.log2(count + 1));
    }

    function render() {
      const filtered = filteredPlaces();
      updateStats(filtered);
      renderMarkers(filtered);
      renderList(filtered);
      document.getElementById("places-empty").hidden = filtered.length > 0;
    }

    function updateStats(filtered) {
      document.querySelector('[data-stat="total-places"]').textContent = placesData.length.toLocaleString();
      document.querySelector('[data-stat="total-checkins"]').textContent = placesData
        .reduce((sum, place) => sum + (Number(place.checkin_count) || 0), 0)
        .toLocaleString();
      document.querySelector('[data-stat="visible-places"]').textContent = filtered.length.toLocaleString();
      document.getElementById("places-count-badge").textContent = `${filtered.length.toLocaleString()}箇所`;
    }

    function renderMarkers(filtered) {
      markerLayer.clearLayers();
      markersByIndex = {};
      const bounds = [];

      filtered.forEach((place) => {
        const marker = L.circleMarker([place.lat, place.lng], {
          renderer: canvasRenderer,
          radius: markerRadius(place),
          fillColor: place.category_color || "#607d8b",
          fillOpacity: 0.72,
          color: "#ffffff",
          weight: 1,
          opacity: 0.9,
        }).addTo(markerLayer);

        marker.bindPopup(popupHtml(place), { maxWidth: 270, className: "custom-leaflet-popup" });
        marker.on("click", () => highlightPlace(place._index));
        markersByIndex[place._index] = marker;
        bounds.push([place.lat, place.lng]);
      });

      if (bounds.length > 1) map.fitBounds(bounds, { padding: [45, 45], maxZoom: 14 });
      else if (bounds.length === 1) map.setView(bounds[0], 14);
    }

    function renderList(filtered) {
      const list = document.getElementById("places-list");
      const visible = filtered.slice(0, LIST_LIMIT);
      list.innerHTML = visible
        .map((place) => {
          const photo = place.photos && place.photos.length
            ? `<img src="${escapeHtml(place.photos[0])}" alt="${escapeHtml(place.name)}の写真" loading="lazy">`
            : `<div class="checkin-item-placeholder">${escapeHtml(place.category_emoji || "📍")}</div>`;
          const comment = place.user_comment ? `<p class="checkin-item-comment">${escapeHtml(place.user_comment)}</p>` : "";
          return `
            <article class="checkin-item" id="place-item-${place._index}">
              <button class="checkin-item-focus" type="button" data-place-index="${place._index}">
                <div class="checkin-item-photo">${photo}</div>
                <div class="checkin-item-body">
                  <div class="checkin-item-heading">
                    <span class="checkin-item-category" style="background:${escapeHtml(place.category_color || "#607d8b")}">${escapeHtml(place.category_emoji || "📍")} ${escapeHtml(place.category_label || "その他")}</span>
                    <span>${escapeHtml(place.date || "")}</span>
                  </div>
                  <h3>${escapeHtml(place.name || "")}</h3>
                  <p class="checkin-item-address">${escapeHtml(place.address || "")}</p>
                  ${comment}
                  <div class="checkin-item-meta">${Number(place.checkin_count) || 1}回チェックイン</div>
                </div>
              </button>
            </article>
          `;
        })
        .join("");

      list.querySelectorAll("[data-place-index]").forEach((button) => {
        button.addEventListener("click", () => focusPlace(Number(button.dataset.placeIndex)));
      });

      if (filtered.length > visible.length) {
        list.insertAdjacentHTML("beforeend", `<p class="checkin-list-note">先頭 ${visible.length} 件を表示しています。検索やカテゴリで絞り込めます。</p>`);
      }
    }

    function focusPlace(index) {
      const place = placesData[index];
      if (!place) return;
      map.setView([place.lat, place.lng], 15, { animate: true, duration: 0.8 });
      if (markersByIndex[index]) setTimeout(() => markersByIndex[index].openPopup(), 250);
      highlightPlace(index);
    }

    function highlightPlace(index) {
      document.querySelectorAll(".checkin-item").forEach((item) => item.classList.remove("active"));
      const target = document.getElementById(`place-item-${index}`);
      if (target) {
        target.classList.add("active");
        target.scrollIntoView({ block: "nearest", behavior: "smooth" });
      }
    }

    function popupHtml(place) {
      const photo = place.photos && place.photos.length ? place.photos[0] : "";
      const photoBlock = photo ? `<div class="popup-image"><img src="${escapeHtml(photo)}" alt="${escapeHtml(place.name || "")}"></div>` : "";
      const commentBlock = place.user_comment ? `<div class="popup-comment">"${escapeHtml(place.user_comment)}"</div>` : "";
      const dateBlock = place.date ? `<div class="popup-date">📅 ${escapeHtml(place.date)} 訪問</div>` : "";
      return `<div class="map-popup-content">${photoBlock}<h4 class="popup-title">${escapeHtml(place.category_emoji || "📍")} ${escapeHtml(place.name || "")}</h4><p class="popup-address">📍 ${escapeHtml(place.address || "")}</p>${commentBlock}${dateBlock}</div>`;
    }

    function escapeHtml(value) {
      return String(value == null ? "" : value).replace(/[&<>"']/g, (character) => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      })[character]);
    }

    async function loadData() {
      const response = await fetch(DATA_URL);
      if (!response.ok) throw new Error("places-data.json load failed");
      const payload = await response.json();
      placesData = Array.isArray(payload.places) ? payload.places : [];
      placesData.forEach((place, index) => {
        place._index = index;
        place._searchText = searchableText(place);
      });
      document.getElementById("places-map-loading").hidden = true;
      render();
    }

    document.addEventListener("DOMContentLoaded", () => {
      const search = document.getElementById("places-search");
      search.addEventListener("input", (event) => {
        window.clearTimeout(searchTimer);
        searchTimer = window.setTimeout(() => {
          currentSearch = event.target.value.trim().toLowerCase();
          render();
        }, 160);
      });

      document.querySelectorAll("[data-group]").forEach((button) => {
        button.addEventListener("click", () => {
          document.querySelectorAll("[data-group]").forEach((item) => item.classList.remove("active"));
          button.classList.add("active");
          currentGroup = button.dataset.group || "all";
          render();
        });
      });

      canvasRenderer = L.canvas({ padding: 0.5 });
      map = L.map("places-map", {
        preferCanvas: true,
        scrollWheelZoom: false,
        renderer: canvasRenderer,
        zoomControl: true,
      }).setView([36.2048, 138.2529], 5);

      map.on("focus", () => map.scrollWheelZoom.enable());
      map.on("blur", () => map.scrollWheelZoom.disable());
      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        maxZoom: 19,
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      }).addTo(map);
      markerLayer = L.layerGroup().addTo(map);
      requestAnimationFrame(() => map.invalidateSize());
      loadData().catch((error) => {
        console.error(error);
        document.getElementById("places-map-loading").textContent = "データの読み込みに失敗しました";
      });
    });
  </script>
</MapLayout>
