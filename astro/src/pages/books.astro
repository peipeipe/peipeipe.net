---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getBooksData } from "@/lib/books";

const data = getBooksData();
const books = data.books;
const initialBooks = books.slice(0, 80);
const serializedBooks = JSON.stringify({ books }).replace(/</g, "\\u003c");

function metaParts(book) {
  return [
    book.author,
    book.publisher,
    book.publishedYear,
    book.readDate ? `${book.readDate}読了` : "",
    book.rating ? `★${book.rating}` : "",
  ].filter(Boolean);
}
---

<BaseLayout title="Books" wide={true}>
  <article class="books-page">
    <header class="books-header">
      <h1>Books</h1>
      <p>
        {data.stats.books}冊 / 引用あり {data.stats.withQuotes}冊 / 引用 {data.stats.quotes}件
      </p>
    </header>

    <form class="books-search" id="books-search" role="search">
      <label for="books-query">Search books</label>
      <input
        id="books-query"
        name="q"
        type="search"
        autocomplete="off"
        spellcheck="false"
        placeholder="タイトル、著者、出版社、引用から検索"
      />
    </form>

    <p class="books-status" id="books-status" aria-live="polite">最近読んだ本</p>

    <ol class="books-list" id="books-list">
      {initialBooks.map((book) => (
        <li class="book-item" id={book.id}>
          <article>
            <header>
              <h2>{book.title}</h2>
              <p>{metaParts(book).join(" / ")}</p>
            </header>
            {book.quotes.length > 0 && (
              <div class="book-quotes">
                {book.quotes.slice(0, 4).map((quote) => (
                  <blockquote>{quote.text}</blockquote>
                ))}
              </div>
            )}
          </article>
        </li>
      ))}
    </ol>
  </article>

  <script type="application/json" id="books-data" set:html={serializedBooks}></script>
  <script is:inline>
    (() => {
      const dataTag = document.getElementById("books-data");
      const input = document.getElementById("books-query");
      const list = document.getElementById("books-list");
      const status = document.getElementById("books-status");
      if (!dataTag || !input || !list || !status) return;

      const { books } = JSON.parse(dataTag.textContent || "{}");

      function normalize(value) {
        return value.normalize("NFKC").toLowerCase().trim();
      }

      function escapeHtml(value) {
        return String(value)
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;");
      }

      function metaParts(book) {
        return [
          book.author,
          book.publisher,
          book.publishedYear,
          book.readDate ? `${book.readDate}読了` : "",
          book.rating ? `★${book.rating}` : "",
        ].filter(Boolean);
      }

      function searchableText(book) {
        return normalize([
          book.title,
          book.author,
          book.publisher,
          book.publishedYear,
          book.readDate,
          (book.tags || []).join(" "),
          (book.quotes || []).map((quote) => quote.text).join(" "),
        ].join(" "));
      }

      function renderBook(book, terms) {
        const quotes = (book.quotes || [])
          .filter((quote) => {
            if (!terms.length) return true;
            const text = normalize(quote.text);
            return terms.some((term) => text.includes(term));
          })
          .slice(0, terms.length ? 8 : 4);

        return `
          <li class="book-item" id="${escapeHtml(book.id)}">
            <article>
              <header>
                <h2>${escapeHtml(book.title)}</h2>
                <p>${escapeHtml(metaParts(book).join(" / "))}</p>
              </header>
              ${quotes.length ? `<div class="book-quotes">${quotes.map((quote) => `<blockquote>${escapeHtml(quote.text)}</blockquote>`).join("")}</div>` : ""}
            </article>
          </li>
        `;
      }

      function render() {
        const query = normalize(input.value);
        const terms = query ? query.split(/\s+/).filter(Boolean) : [];
        const filtered = books.filter((book) => {
          if (!terms.length) return true;
          const text = searchableText(book);
          return terms.every((term) => text.includes(term));
        });
        const displayBooks = filtered.slice(0, terms.length ? 120 : 80);

        status.textContent = terms.length ? `${filtered.length}冊見つかりました` : "最近読んだ本";
        list.innerHTML = displayBooks.length
          ? displayBooks.map((book) => renderBook(book, terms)).join("")
          : '<li class="books-empty">該当する本はありません。</li>';
      }

      input.addEventListener("input", render);
      render();
    })();
  </script>

  <style>
    .books-page {
      padding-bottom: 2rem;
    }

    .books-header {
      margin-bottom: 1.25rem;
    }

    .books-header h1 {
      margin: 0 0 0.35rem;
      font-size: 30px;
      line-height: 1.25;
    }

    .books-header p,
    .books-status {
      margin: 0;
      color: #666;
      font-size: 15px;
    }

    .books-search {
      margin: 0 0 1rem;
    }

    .books-search label {
      display: inline-block;
      margin-bottom: 0.45rem;
      color: #555;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .books-search input {
      width: 100%;
      border: 1px solid #d6d6d6;
      border-radius: 4px;
      background: #fff;
      padding: 0.75rem 0.9rem;
      font-size: 16px;
      line-height: 1.3;
    }

    .books-status {
      margin-bottom: 0.75rem;
    }

    .books-list {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 14px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .book-item {
      min-width: 0;
      border: 1px solid #e3e3e3;
      border-radius: 6px;
      background: #fff;
    }

    .book-item article {
      padding: 14px;
    }

    .book-item h2 {
      margin: 0 0 0.35rem;
      font-size: 18px;
      line-height: 1.35;
      overflow-wrap: anywhere;
    }

    .book-item header p {
      margin: 0;
      color: #666;
      font-size: 13px;
      line-height: 1.45;
      overflow-wrap: anywhere;
    }

    .book-quotes {
      margin-top: 0.85rem;
    }

    .book-quotes blockquote {
      margin: 0.7rem 0 0;
      border-left: 2px solid #8a8a8a;
      padding-left: 0.8rem;
      color: #444;
      font-size: 14px;
      line-height: 1.65;
      white-space: pre-wrap;
      overflow-wrap: anywhere;
    }

    .books-empty {
      color: #666;
    }
  </style>
</BaseLayout>
