---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getBooksData } from "@/lib/books";

const data = getBooksData();
const books = data.books;
const initialBooks = books.slice(0, 80);
const years = Array.from(new Set(books.map((book) => book.readDate?.slice(0, 4)).filter(Boolean))).sort((a, b) => b.localeCompare(a));
const serializedBooks = JSON.stringify({ books }).replace(/</g, "\\u003c");

function metaParts(book) {
  return [
    book.author,
    book.publisher,
    book.publishedYear,
    book.readDate ? `${book.readDate}読了` : "",
    book.rating ? `★${book.rating}` : "",
  ].filter(Boolean);
}

function ratingLabel(book) {
  return book.rating ? "★".repeat(book.rating) : "";
}
---

<BaseLayout title="Books" wide={true}>
  <article class="books-page">
    <header class="books-header">
      <div>
        <h1>Books</h1>
        <p>読んだ本と、残しておきたい引用</p>
      </div>
      <dl class="books-stats" aria-label="Books stats">
        <div>
          <dt>Books</dt>
          <dd>{data.stats.books}</dd>
        </div>
        <div>
          <dt>Quoted</dt>
          <dd>{data.stats.withQuotes}</dd>
        </div>
        <div>
          <dt>Quotes</dt>
          <dd>{data.stats.quotes}</dd>
        </div>
      </dl>
    </header>

    <div class="books-browser">
      <aside class="books-toolbar">
        <form class="books-search" id="books-search" role="search">
          <label for="books-query">Search books</label>
          <input
            id="books-query"
            name="q"
            type="search"
            autocomplete="off"
            spellcheck="false"
            placeholder="タイトル、著者、出版社、引用から検索"
          />
          <div class="books-filters" aria-label="Book filters">
            <label>
              <span>Year</span>
              <select id="books-year" name="year">
                <option value="">すべて</option>
                {years.map((year) => <option value={year}>{year}</option>)}
              </select>
            </label>
            <label>
              <span>Rating</span>
              <select id="books-rating" name="rating">
                <option value="">すべて</option>
                <option value="5">★5</option>
                <option value="4">★4以上</option>
                <option value="3">★3以上</option>
              </select>
            </label>
            <label class="books-check">
              <input id="books-quotes-only" name="quotes" type="checkbox" />
              <span>引用あり</span>
            </label>
          </div>
        </form>
      </aside>

      <section class="books-results" aria-label="Books results">
        <p class="books-status" id="books-status" aria-live="polite">最近読んだ本</p>
        <ol class="books-list" id="books-list">
          {initialBooks.map((book) => (
            <li class:list={["book-item", { "has-quotes": book.quotes.length > 0 }]} id={book.id}>
              <article>
                <div class="book-record">
                  {book.coverUrl && (
                    <a class="book-cover" href={book.amazonUrl || undefined} target="_blank" rel="nofollow noopener" aria-label={`${book.title} on Amazon`}>
                      <img src={book.coverUrl} alt="" loading="lazy" onerror="this.closest('.book-cover')?.remove()" />
                    </a>
                  )}
                  <div class="book-body">
                    <header>
                      <div class="book-title-row">
                        <h2>{book.amazonUrl ? <a href={book.amazonUrl} target="_blank" rel="nofollow noopener">{book.title}</a> : book.title}</h2>
                        {book.quotes.length > 0 && <span class="book-quote-count">{book.quotes.length} quotes</span>}
                      </div>
                      <p class="book-meta">{metaParts(book).join(" / ")}</p>
                      {ratingLabel(book) && <p class="book-rating" aria-label={`Rating ${book.rating}`}>{ratingLabel(book)}</p>}
                    </header>
                  </div>
                </div>
                {book.quotes.length > 0 && (
                  <div class="book-quotes">
                    {book.quotes.map((quote) => (
                      <blockquote>{quote.text}</blockquote>
                    ))}
                  </div>
                )}
              </article>
            </li>
          ))}
        </ol>
        <button class="books-more" id="books-more" type="button" hidden>もっと見る</button>
      </section>
    </div>
  </article>

  <script type="application/json" id="books-data" set:html={serializedBooks}></script>
  <script is:inline>
    (() => {
      const dataTag = document.getElementById("books-data");
      const input = document.getElementById("books-query");
      const yearSelect = document.getElementById("books-year");
      const ratingSelect = document.getElementById("books-rating");
      const quotesOnly = document.getElementById("books-quotes-only");
      const list = document.getElementById("books-list");
      const status = document.getElementById("books-status");
      const moreButton = document.getElementById("books-more");
      if (!dataTag || !input || !yearSelect || !ratingSelect || !quotesOnly || !list || !status || !moreButton) return;

      const { books } = JSON.parse(dataTag.textContent || "{}");
      const defaultLimit = 80;
      const filteredLimit = 120;
      const pageSize = 80;
      let displayLimit = defaultLimit;

      function normalize(value) {
        return value.normalize("NFKC").toLowerCase().trim();
      }

      function escapeHtml(value) {
        return String(value)
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;");
      }

      function metaParts(book) {
        return [
          book.author,
          book.publisher,
          book.publishedYear,
          book.readDate ? `${book.readDate}読了` : "",
          book.rating ? `★${book.rating}` : "",
        ].filter(Boolean);
      }

      function ratingLabel(book) {
        return book.rating ? "★".repeat(book.rating) : "";
      }

      function searchableText(book) {
        return normalize([
          book.title,
          book.author,
          book.publisher,
          book.publishedYear,
          book.readDate,
          (book.tags || []).join(" "),
          (book.quotes || []).map((quote) => quote.text).join(" "),
        ].join(" "));
      }

      function renderBook(book, terms) {
        const matchingQuotes = (book.quotes || [])
          .filter((quote) => {
            if (!terms.length) return true;
            const text = normalize(quote.text);
            return terms.some((term) => text.includes(term));
          });
        const sourceQuotes = terms.length && matchingQuotes.length ? matchingQuotes : (book.quotes || []);
        const quotes = sourceQuotes;
        const rating = ratingLabel(book);

        const cover = book.coverUrl
          ? `<a class="book-cover" href="${escapeHtml(book.amazonUrl || "#")}" target="_blank" rel="nofollow noopener" aria-label="${escapeHtml(`${book.title} on Amazon`)}"><img src="${escapeHtml(book.coverUrl)}" alt="" loading="lazy" onerror="this.closest('.book-cover')?.remove()"></a>`
          : "";

        return `
          <li class="book-item ${book.quotes?.length ? "has-quotes" : ""}" id="${escapeHtml(book.id)}">
            <article>
              <div class="book-record">
                ${cover}
                <div class="book-body">
                  <header>
                    <div class="book-title-row">
                      <h2>${book.amazonUrl ? `<a href="${escapeHtml(book.amazonUrl)}" target="_blank" rel="nofollow noopener">${escapeHtml(book.title)}</a>` : escapeHtml(book.title)}</h2>
                      ${book.quotes?.length ? `<span class="book-quote-count">${escapeHtml(book.quotes.length)} quotes</span>` : ""}
                    </div>
                    <p class="book-meta">${escapeHtml(metaParts(book).join(" / "))}</p>
                    ${rating ? `<p class="book-rating" aria-label="Rating ${escapeHtml(book.rating)}">${escapeHtml(rating)}</p>` : ""}
                  </header>
                </div>
              </div>
              ${quotes.length ? `<div class="book-quotes">${quotes.map((quote) => `<blockquote>${escapeHtml(quote.text)}</blockquote>`).join("")}</div>` : ""}
            </article>
          </li>
        `;
      }

      function render() {
        const query = normalize(input.value);
        const terms = query ? query.split(/\s+/).filter(Boolean) : [];
        const year = yearSelect.value;
        const minimumRating = ratingSelect.value ? Number(ratingSelect.value) : 0;
        const wantsQuotes = quotesOnly.checked;
        const isFiltered = terms.length || year || minimumRating || wantsQuotes;
        const filtered = books.filter((book) => {
          if (year && !book.readDate?.startsWith(`${year}-`)) return false;
          if (minimumRating && (!book.rating || book.rating < minimumRating)) return false;
          if (wantsQuotes && !book.quotes?.length) return false;
          if (!terms.length) return true;
          const text = searchableText(book);
          return terms.every((term) => text.includes(term));
        });
        const baseLimit = isFiltered ? filteredLimit : defaultLimit;
        const limit = Math.max(displayLimit, baseLimit);
        const displayBooks = filtered.slice(0, limit);
        const shownLabel = filtered.length > displayBooks.length ? `${displayBooks.length} / ` : "";

        status.textContent = isFiltered ? `${shownLabel}${filtered.length}冊見つかりました` : `${shownLabel}最近読んだ本`;
        list.innerHTML = displayBooks.length
          ? displayBooks.map((book) => renderBook(book, terms)).join("")
          : '<li class="books-empty">該当する本はありません。</li>';
        moreButton.hidden = displayBooks.length >= filtered.length;
      }

      function resetAndRender() {
        displayLimit = termsAreActive() ? filteredLimit : defaultLimit;
        render();
      }

      function termsAreActive() {
        return Boolean(normalize(input.value) || yearSelect.value || ratingSelect.value || quotesOnly.checked);
      }

      input.addEventListener("input", resetAndRender);
      yearSelect.addEventListener("change", resetAndRender);
      ratingSelect.addEventListener("change", resetAndRender);
      quotesOnly.addEventListener("change", resetAndRender);
      moreButton.addEventListener("click", () => {
        displayLimit += pageSize;
        render();
      });
      render();
    })();
  </script>

  <style is:global>
    .books-page {
      --books-ink: #24211f;
      --books-muted: #6d6862;
      --books-subtle: #8d867c;
      --books-rule: #dfd8ce;
      --books-paper: #fffdf9;
      --books-panel: #f6f3ed;
      --books-quote: #fffaf1;
      --books-accent: #80614e;
      --books-field: #fff;
      --books-focus: rgba(128, 97, 78, 0.22);
      --books-cover-border: #ddd4c8;
      --books-cover-bg: #eee9df;
      --books-rating: #a96516;
      --books-quote-border: #a98b76;
      --books-quote-gradient: linear-gradient(90deg, rgba(169, 139, 118, 0.11), rgba(255, 250, 241, 0));
      padding-bottom: 2.4rem;
    }

    html[data-theme="dark"] .books-page {
      --books-ink: #ece5da;
      --books-muted: #b9ad9e;
      --books-subtle: #92897f;
      --books-rule: #463d35;
      --books-paper: #1b1815;
      --books-panel: #231f1a;
      --books-quote: #211d18;
      --books-accent: #d5ad86;
      --books-field: #161411;
      --books-focus: rgba(213, 173, 134, 0.24);
      --books-cover-border: #554a3f;
      --books-cover-bg: #2b251f;
      --books-rating: #e6b15f;
      --books-quote-border: #bf9874;
      --books-quote-gradient: linear-gradient(90deg, rgba(191, 152, 116, 0.16), rgba(35, 31, 26, 0));
    }

    .books-header {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 1rem;
      align-items: end;
      max-width: 1180px;
      margin: 0 auto 1.4rem;
      border-bottom: 1px solid var(--books-rule);
      padding-bottom: 1rem;
    }

    .books-header h1 {
      margin: 0 0 0.35rem;
      color: var(--books-ink);
      font-size: 38px;
      line-height: 1.15;
    }

    .books-header p {
      margin: 0;
      color: var(--books-muted);
      font-size: 15px;
    }

    .books-stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1px;
      margin: 0;
      overflow: hidden;
      border: 1px solid var(--books-rule);
      border-radius: 6px;
      background: var(--books-rule);
    }

    .books-stats div {
      background: var(--books-paper);
      padding: 10px 12px;
    }

    .books-stats dt {
      color: var(--books-subtle);
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
    }

    .books-stats dd {
      margin: 2px 0 0;
      color: var(--books-ink);
      font-size: 23px;
      font-weight: 700;
      line-height: 1.1;
    }

    .books-browser {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 1rem;
      max-width: 1180px;
      margin: 0 auto;
    }

    .books-toolbar {
      align-self: start;
      border: 1px solid var(--books-rule);
      border-radius: 6px;
      background: var(--books-panel);
      padding: 14px;
    }

    .books-search {
      margin: 0;
    }

    .books-search > label,
    .books-filters span {
      display: inline-block;
      margin-bottom: 0.45rem;
      color: var(--books-muted);
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
    }

    .books-search input[type="search"],
    .books-filters select {
      width: 100%;
      border: 1px solid var(--books-rule);
      border-radius: 5px;
      background: var(--books-field);
      color: var(--books-ink);
      padding: 0.72rem 0.82rem;
      font-size: 16px;
      line-height: 1.3;
    }

    .books-search input:focus,
    .books-filters select:focus,
    .books-check input:focus {
      outline: 2px solid var(--books-focus);
      outline-offset: 1px;
      border-color: var(--books-accent);
    }

    .books-filters {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
      gap: 10px;
      margin-top: 0.85rem;
    }

    .books-filters label {
      min-width: 0;
    }

    .books-check {
      display: inline-flex;
      gap: 8px;
      align-items: center;
      min-height: 43px;
      border: 1px solid var(--books-rule);
      border-radius: 5px;
      background: var(--books-field);
      padding: 0 0.78rem;
    }

    .books-check input {
      width: 18px;
      height: 18px;
      accent-color: var(--books-accent);
    }

    .books-check span {
      margin: 0;
      color: var(--books-ink);
      text-transform: none;
    }

    .books-results {
      min-width: 0;
    }

    .books-status {
      margin: 0 0 0.8rem;
      color: var(--books-muted);
      font-size: 14px;
    }

    .books-list {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 16px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .book-item {
      min-width: 0;
      border: 1px solid var(--books-rule);
      border-radius: 6px;
      background: var(--books-paper);
      overflow: hidden;
    }

    .book-item article {
      padding: 16px;
    }

    .book-record {
      display: grid;
      grid-template-columns: 72px minmax(0, 1fr);
      gap: 14px;
      align-items: start;
    }

    .book-record:not(:has(.book-cover)) {
      grid-template-columns: minmax(0, 1fr);
    }

    .book-cover {
      display: block;
      width: 72px;
      min-height: 102px;
      border: 1px solid var(--books-cover-border);
      border-radius: 4px;
      background: var(--books-cover-bg);
      overflow: hidden;
    }

    .book-cover img {
      display: block;
      width: 100%;
      height: auto;
    }

    .book-body {
      min-width: 0;
      padding-top: 1px;
    }

    .book-title-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 0.45rem;
      align-items: start;
    }

    .book-item h2 {
      margin: 0;
      color: var(--books-ink);
      font-size: 20px;
      line-height: 1.38;
      overflow-wrap: anywhere;
    }

    .book-item h2 a {
      color: inherit;
      text-decoration: none;
    }

    .book-item h2 a:hover,
    .book-item h2 a:focus {
      color: var(--books-accent);
      text-decoration: underline;
    }

    .book-quote-count {
      width: max-content;
      border: 1px solid var(--books-rule);
      border-radius: 999px;
      background: var(--books-field);
      color: var(--books-accent);
      padding: 3px 9px;
      font-size: 12px;
      font-weight: 700;
      line-height: 1.2;
    }

    .book-meta {
      margin: 0.55rem 0 0;
      color: var(--books-muted);
      font-size: 13px;
      line-height: 1.55;
      overflow-wrap: anywhere;
    }

    .book-rating {
      margin: 0.35rem 0 0;
      color: var(--books-rating);
      font-size: 12px;
      line-height: 1.2;
    }

    .book-quotes {
      display: grid;
      gap: 0.95rem;
      margin-top: 1rem;
      padding-top: 1rem;
      border-top: 1px solid var(--books-rule);
    }

    .book-quotes blockquote {
      margin: 0;
      border-left: 4px solid var(--books-quote-border);
      background: var(--books-quote-gradient);
      padding: 0.15rem 0 0.18rem 1rem;
      color: var(--books-ink);
      font-size: 15px;
      line-height: 1.9;
      white-space: pre-wrap;
      overflow-wrap: anywhere;
    }

    .books-empty {
      border: 1px solid var(--books-rule);
      border-radius: 6px;
      background: var(--books-paper);
      color: var(--books-muted);
      padding: 1rem;
    }

    .books-more {
      display: block;
      margin: 1.25rem auto 0;
      border: 1px solid var(--books-accent);
      border-radius: 5px;
      background: var(--books-field);
      color: var(--books-accent);
      padding: 0.72rem 1.2rem;
      font-size: 15px;
      font-weight: 700;
      line-height: 1.2;
      cursor: pointer;
    }

    .books-more[hidden] {
      display: none;
    }

    .books-more:hover,
    .books-more:focus {
      background: var(--books-accent);
      color: #fff;
    }

    @media (min-width: 720px) {
      .books-header {
        grid-template-columns: minmax(0, 1fr) minmax(300px, 420px);
      }

      .book-record {
        grid-template-columns: 88px minmax(0, 1fr);
        gap: 18px;
      }

      .book-cover {
        width: 88px;
        min-height: 124px;
      }

      .book-title-row {
        grid-template-columns: minmax(0, 1fr) auto;
      }
    }

    @media (min-width: 980px) {
      .books-browser {
        grid-template-columns: 285px minmax(0, 1fr);
        align-items: start;
      }

      .books-toolbar {
        position: sticky;
        top: 18px;
      }
    }

    @media (min-width: 1100px) {
      .book-item article {
        padding: 20px;
      }

      .book-record {
        grid-template-columns: 104px minmax(0, 1fr);
      }

      .book-cover {
        width: 104px;
        min-height: 147px;
      }

      .book-quotes blockquote {
        font-size: 16px;
      }
    }

    @media (max-width: 520px) {
      .books-header h1 {
        font-size: 32px;
      }

      .books-stats dd {
        font-size: 20px;
      }

      .book-item article {
        padding: 13px;
      }

      .book-record {
        grid-template-columns: 62px minmax(0, 1fr);
        gap: 12px;
      }

      .book-cover {
        width: 62px;
        min-height: 88px;
      }

      .book-item h2 {
        font-size: 17px;
      }

      .book-quotes blockquote {
        padding: 0.82rem 0.85rem;
        font-size: 14px;
        line-height: 1.85;
      }
    }
  </style>
</BaseLayout>
