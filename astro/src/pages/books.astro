---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getBooksData } from "@/lib/books";

const data = getBooksData();
const books = data.books;
const initialBooks = books.slice(0, 80);
const serializedBooks = JSON.stringify({ books }).replace(/</g, "\\u003c");

function metaParts(book) {
  return [
    book.author,
    book.publisher,
    book.publishedYear,
    book.readDate ? `${book.readDate}読了` : "",
    book.rating ? `★${book.rating}` : "",
  ].filter(Boolean);
}

function ratingLabel(book) {
  return book.rating ? "★".repeat(book.rating) : "";
}
---

<BaseLayout title="Books" robots="noindex, nofollow" wide={true}>
  <article class="books-page">
    <header class="books-header">
      <div>
        <h1>Books</h1>
        <p>読んだ本と、残しておきたい引用</p>
      </div>
      <dl class="books-stats" aria-label="Books stats">
        <div>
          <dt>Books</dt>
          <dd>{data.stats.books}</dd>
        </div>
        <div>
          <dt>Quoted</dt>
          <dd>{data.stats.withQuotes}</dd>
        </div>
        <div>
          <dt>Quotes</dt>
          <dd>{data.stats.quotes}</dd>
        </div>
      </dl>
    </header>

    <div class="books-toolbar">
      <form class="books-search" id="books-search" role="search">
        <label for="books-query">Search books</label>
        <input
          id="books-query"
          name="q"
          type="search"
          autocomplete="off"
          spellcheck="false"
          placeholder="タイトル、著者、出版社、引用から検索"
        />
      </form>
      <p class="books-status" id="books-status" aria-live="polite">最近読んだ本</p>
    </div>

    <ol class="books-list" id="books-list">
      {initialBooks.map((book) => (
        <li class:list={["book-item", { "has-quotes": book.quotes.length > 0 }]} id={book.id}>
          <article>
            <header>
              <div class="book-title-row">
                <h2>{book.title}</h2>
                {book.quotes.length > 0 && <span class="book-quote-count">{book.quotes.length}</span>}
              </div>
              <p class="book-meta">{metaParts(book).join(" / ")}</p>
              {ratingLabel(book) && <p class="book-rating" aria-label={`Rating ${book.rating}`}>{ratingLabel(book)}</p>}
            </header>
            {book.quotes.length > 0 && (
              <div class="book-quotes">
                {book.quotes.slice(0, 2).map((quote) => (
                  <blockquote>{quote.text}</blockquote>
                ))}
              </div>
            )}
          </article>
        </li>
      ))}
    </ol>
  </article>

  <script type="application/json" id="books-data" set:html={serializedBooks}></script>
  <script is:inline>
    (() => {
      const dataTag = document.getElementById("books-data");
      const input = document.getElementById("books-query");
      const list = document.getElementById("books-list");
      const status = document.getElementById("books-status");
      if (!dataTag || !input || !list || !status) return;

      const { books } = JSON.parse(dataTag.textContent || "{}");

      function normalize(value) {
        return value.normalize("NFKC").toLowerCase().trim();
      }

      function escapeHtml(value) {
        return String(value)
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;");
      }

      function metaParts(book) {
        return [
          book.author,
          book.publisher,
          book.publishedYear,
          book.readDate ? `${book.readDate}読了` : "",
          book.rating ? `★${book.rating}` : "",
        ].filter(Boolean);
      }

      function ratingLabel(book) {
        return book.rating ? "★".repeat(book.rating) : "";
      }

      function searchableText(book) {
        return normalize([
          book.title,
          book.author,
          book.publisher,
          book.publishedYear,
          book.readDate,
          (book.tags || []).join(" "),
          (book.quotes || []).map((quote) => quote.text).join(" "),
        ].join(" "));
      }

      function renderBook(book, terms) {
        const quotes = (book.quotes || [])
          .filter((quote) => {
            if (!terms.length) return true;
            const text = normalize(quote.text);
            return terms.some((term) => text.includes(term));
          })
          .slice(0, terms.length ? 6 : 2);
        const rating = ratingLabel(book);

        return `
          <li class="book-item ${book.quotes?.length ? "has-quotes" : ""}" id="${escapeHtml(book.id)}">
            <article>
              <header>
                <div class="book-title-row">
                  <h2>${escapeHtml(book.title)}</h2>
                  ${book.quotes?.length ? `<span class="book-quote-count">${escapeHtml(book.quotes.length)}</span>` : ""}
                </div>
                <p class="book-meta">${escapeHtml(metaParts(book).join(" / "))}</p>
                ${rating ? `<p class="book-rating" aria-label="Rating ${escapeHtml(book.rating)}">${escapeHtml(rating)}</p>` : ""}
              </header>
              ${quotes.length ? `<div class="book-quotes">${quotes.map((quote) => `<blockquote>${escapeHtml(quote.text)}</blockquote>`).join("")}</div>` : ""}
            </article>
          </li>
        `;
      }

      function render() {
        const query = normalize(input.value);
        const terms = query ? query.split(/\s+/).filter(Boolean) : [];
        const filtered = books.filter((book) => {
          if (!terms.length) return true;
          const text = searchableText(book);
          return terms.every((term) => text.includes(term));
        });
        const displayBooks = filtered.slice(0, terms.length ? 120 : 80);

        status.textContent = terms.length ? `${filtered.length}冊見つかりました` : "最近読んだ本";
        list.innerHTML = displayBooks.length
          ? displayBooks.map((book) => renderBook(book, terms)).join("")
          : '<li class="books-empty">該当する本はありません。</li>';
      }

      input.addEventListener("input", render);
      render();
    })();
  </script>

  <style>
    .books-page {
      --books-ink: #252525;
      --books-muted: #666;
      --books-rule: #e3e0da;
      --books-paper: #fff;
      --books-soft: #f7f6f3;
      --books-accent: #8f4f3f;
      padding-bottom: 2rem;
    }

    .books-header {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 1rem;
      align-items: end;
      margin-bottom: 1.25rem;
      border-bottom: 1px solid var(--books-rule);
      padding-bottom: 1.1rem;
    }

    .books-header h1 {
      margin: 0 0 0.35rem;
      color: var(--books-ink);
      font-size: 34px;
      line-height: 1.25;
    }

    .books-header p,
    .books-status {
      margin: 0;
      color: var(--books-muted);
      font-size: 15px;
    }

    .books-stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
      margin: 0;
    }

    .books-stats div {
      border-left: 3px solid var(--books-accent);
      background: var(--books-soft);
      padding: 8px 10px;
    }

    .books-stats dt {
      color: var(--books-muted);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .books-stats dd {
      margin: 1px 0 0;
      color: var(--books-ink);
      font-size: 23px;
      font-weight: 700;
      line-height: 1.1;
    }

    .books-toolbar {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 0.7rem;
      align-items: end;
      margin-bottom: 1.1rem;
      border-bottom: 1px solid var(--books-rule);
      padding-bottom: 1rem;
    }

    .books-search {
      margin: 0;
    }

    .books-search label {
      display: inline-block;
      margin-bottom: 0.45rem;
      color: #555;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .books-search input {
      width: 100%;
      border: 1px solid #d6d6d6;
      border-radius: 4px;
      background: #fff;
      padding: 0.78rem 0.9rem;
      font-size: 16px;
      line-height: 1.3;
    }

    .books-search input:focus {
      outline: 2px solid rgba(143, 79, 63, 0.2);
      outline-offset: 1px;
      border-color: var(--books-accent);
    }

    .books-status {
      justify-self: start;
      color: var(--books-muted);
      font-size: 14px;
    }

    .books-list {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 12px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .book-item {
      position: relative;
      min-width: 0;
      border: 1px solid var(--books-rule);
      border-radius: 6px;
      background: var(--books-paper);
      box-shadow: 0 1px 0 rgba(0, 0, 0, 0.03);
      overflow: hidden;
    }

    .book-item::before {
      position: absolute;
      inset: 0 auto 0 0;
      width: 5px;
      background: #b8b1a4;
      content: "";
    }

    .book-item.has-quotes::before {
      background: var(--books-accent);
    }

    .book-item article {
      padding: 14px 14px 15px 18px;
    }

    .book-title-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 8px;
      align-items: start;
    }

    .book-item h2 {
      margin: 0;
      color: var(--books-ink);
      font-size: 18px;
      line-height: 1.45;
      overflow-wrap: anywhere;
    }

    .book-quote-count {
      min-width: 26px;
      border: 1px solid rgba(143, 79, 63, 0.35);
      border-radius: 999px;
      color: var(--books-accent);
      padding: 2px 7px;
      font-size: 12px;
      font-weight: 700;
      line-height: 1.3;
      text-align: center;
    }

    .book-meta {
      margin: 0.35rem 0 0;
      color: var(--books-muted);
      font-size: 13px;
      line-height: 1.45;
      overflow-wrap: anywhere;
    }

    .book-rating {
      margin: 0.25rem 0 0;
      color: #b36b18;
      font-size: 12px;
      letter-spacing: 0.04em;
      line-height: 1.2;
    }

    .book-quotes {
      margin-top: 0.95rem;
      border-top: 1px solid #efede8;
      padding-top: 0.15rem;
    }

    .book-quotes blockquote {
      margin: 0.75rem 0 0;
      border-left: 2px solid #b7a093;
      padding-left: 0.75rem;
      color: #444;
      font-size: 14px;
      line-height: 1.7;
      white-space: pre-wrap;
      overflow-wrap: anywhere;
    }

    .books-empty {
      color: #666;
    }

    @media (min-width: 720px) {
      .books-header {
        grid-template-columns: minmax(0, 1fr) minmax(300px, 430px);
      }

      .books-toolbar {
        grid-template-columns: minmax(0, 1fr) auto;
      }

      .books-status {
        justify-self: end;
        padding-bottom: 0.8rem;
      }
    }
  </style>
</BaseLayout>
