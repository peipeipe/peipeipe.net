---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  wide?: boolean;
}

const siteName = "peipeipe.net";
const siteDescription = "読んだ本とやったこと";
const siteUrl = "https://www.peipeipe.net";
const avatar = "/images/jekyll-logo.png";
const { title, description = siteDescription, canonicalPath = Astro.url.pathname, wide = false } = Astro.props;
const pageTitle = title ? `${title} - ${siteName} - ${siteDescription}` : `${siteName} - ${siteDescription}`;
const canonicalUrl = new URL(canonicalPath, siteUrl).toString();
---

<!doctype html>
<html lang="ja">
  <head>
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-N8NFQ8K');
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="@peipeipe" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <link rel="me" href="https://mstdn.jp/@peipeipe" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={`${siteName} - ${siteDescription}`} href="/feed.xml" />
    <slot name="head" />
  </head>
  <body>
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-N8NFQ8K"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe>
    </noscript>
    <div class="wrapper-masthead">
      <div class="container">
        <header class="masthead clearfix">
          <a href="/" class="site-avatar" aria-label={siteName}>
            <img src={avatar} alt="" />
          </a>

          <div class="site-info">
            <h1 class="site-name"><a href="/">{siteName}</a></h1>
            <p class="site-description">{siteDescription}</p>
          </div>

          <nav class="nav" aria-label="Main navigation">
            <a href="/">Blog</a>
            <a href="/diary/">Diary</a>
            <a href="/places/">Places</a>
            <a href="/activity/">Activity</a>
            <a href="/mountains/">Mountains</a>
            <a href="/about">About</a>
            <a href="/search">Search</a>
          </nav>
        </header>
      </div>
    </div>

    <main id="main" class:list={["container", { "container-wide": wide }]}>
      <slot />
    </main>

    <div class="wrapper-footer">
      <div class="container">
        <footer class="footer">
          <a href="/feed.xml" aria-label="RSS" title="RSS">RSS</a>
          <a href="https://www.twitter.com/peipeipe" aria-label="Twitter" title="Twitter">Twitter</a>
          <a href="https://mstdn.jp/@peipeipe" rel="me" aria-label="Mastodon" title="Mastodon">Mastodon</a>
          <a href="https://youtube.com/@peipeipe1627" aria-label="YouTube" title="YouTube">YouTube</a>
          <a href="https://creators.spotify.com/pod/show/itsurvival/" aria-label="Podcast" title="Podcast">Podcast</a>
        </footer>
      </div>
    </div>
  </body>
</html>
