{
  "name": "peipeipe-net-astro",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/finalize-public-assets.mjs",
    "preview": "astro preview",
    "pages:dev": "wrangler pages dev dist",
    "pages:create": "wrangler pages project create peipeipe-net-astro --production-branch master",
    "pages:deploy": "npm run build && wrangler pages deploy dist --project-name peipeipe-net-astro",
    "manifest": "node scripts/build-url-manifest.mjs",
    "check:legacy-slugs": "node scripts/check-legacy-slugs.mjs"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.6.0",
    "astro": "^7.0.3",
    "fast-glob": "^3.3.3",
    "js-yaml": "^5.2.0",
    "marked": "^18.0.5"
  },
  "devDependencies": {
    "@types/node": "^26.1.0"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
